@model Catgeory
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">Edit new Category</h3>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post">
                <div class="mb-3">
                    <label for=Name" class="form-label">Name</label>
                    <input class="form-control"  placeholder="Enter category name" asp-for="Name">
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Description" class="form-label">Description</label>
                    <textarea class="form-control" placeholder="Description" id="Description" rows="5" asp-for="Description"></textarea>
					<span asp-validation-for="Description" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label for="Status" class="form-label">Status</label>
                    <select name="status" class="form-select" id="Status">
                        @if (Model.Status)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">Inactive</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>Inactive</option>
						}
                      
                    </select>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
@section Scripts {
  
    <partial name="~/Views/Shared/_ValidationScriptsPartial.cshtml" />
}
