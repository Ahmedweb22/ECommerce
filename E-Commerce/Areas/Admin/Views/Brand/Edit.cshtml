@model Brand
<div class="container">
    <div class="row mb-3 align-items-center my-3">
        <div class="col-md-6">
            <h3 class="display-6">Edit new Category</h3>
        </div>
    </div>

    <div class="row my-3">
        <div class="col-12">
            <form method="post" enctype="multipart/form-data">
				<input type="hidden" name="id" value="@Model.Id" />
                <div class="mb-3">
                    <label for=Name" class="form-label">Name</label>
                    <input class="form-control" id="Name" placeholder="Enter category name" name="name" value="@Model.Name"
                    onchange="previewImage(event)">
                </div>
       
        <div class="mb-3">
            <label for="logo" class="form-label">Logo</label>
            <input type="file" class="form-control" id="Logo" placeholder="Enter brand logo" name="logo" multiple>
        </div>
            <div class="mb-3">
                <img id="preview"
						 src="~/img/brand_logos/@Model.Logo" alt="Current Image" class="img-thumbnail" />
                         </div>

                <div class="mb-3">
                    <label for="Status" class="form-label">Status</label>
                    <select name="status" class="form-select" id="Status">
                        @if (Model.Status)
                        {
                            <option value="true" selected>Active</option>
                            <option value="false">Inactive</option>
                        }
                        else
                        {
                            <option value="true">Active</option>
                            <option value="false" selected>Inactive</option>
						}
                      
                    </select>
                </div>
                <button type="submit" class="btn btn-primary">Submit</button>
            </form>
        </div>
    </div>
</div>
<script>
    function previewImage(event) {
	const input = event.target;
	const preview = document.getElementById('preview');
	if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
		}
		reader.readAsDataURL(input.files[0]);
    }
</script>